# Django Core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=core.settings.prod

# Database (leave DB_NAME blank to use SQLite in development)
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis (leave blank to use in-memory channel layer in development)
CHANNEL_REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
FRONTEND_APP_URL=http://localhost:3000

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=no-reply@example.com
EMAIL_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com
SUPPORT_EMAIL=support@example.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_API_BASE_URL=https://api.razorpay.com/v1

# OpenAI (Chatbot)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Throttling (optional overrides)
THROTTLE_RATE_ANON=100/hour
THROTTLE_RATE_USER=2000/hour
THROTTLE_RATE_AUTH=10/minute
THROTTLE_RATE_REGISTER=5/minute
THROTTLE_RATE_ORDER_CREATE=30/hour
THROTTLE_RATE_PAYMENTS=60/hour
THROTTLE_RATE_ADMIN=120/hour

# Logging
LOG_LEVEL=INFO
# Set LOG_FORMAT=json in production for structured/machine-parseable log lines
LOG_FORMAT=text

# Production HTTPS (prod.py)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Cache (leave blank to use in-memory cache in development)
CACHE_REDIS_URL=redis://localhost:6379/1
CACHE_TTL_PRODUCT_LIST=300
CACHE_TTL_ANALYTICS=600
